{
    "agent": {
        "debug": true
    },
    "logs": {
        "logs_collected": {
            "journald": {
                "collect_list": [
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-units",
                        "units": ["amazon-ssm-agent"],
                        "retention_in_days": 1
                    },
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-priority",
                        "priority": "err",
                        "retention_in_days": 1
                    },
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-matches",
                        "matches": [{"_UID": "0"}],
                        "retention_in_days": 1
                    },
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-regex",
                        "filters": [
                            {"type": "include", "expression": ".*error.*|.*failed.*"}
                        ],
                        "retention_in_days": 1
                    }
                ]
            }
        },
        "force_flush_interval": 5
    }
}
