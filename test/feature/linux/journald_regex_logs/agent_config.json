{
    "agent": {
        "debug": true
    },
    "logs": {
        "logs_collected": {
            "journald": {
                "collect_list": [
                    {
                        "log_group_name": "{instance_id}",
                        "log_stream_name": "journald-regex",
                        "filters": [
                            {"type": "include", "expression": ".*Database.*|.*failed.*"}
                        ],
                        "retention_in_days": 1
                    }
                ]
            }
        },
        "force_flush_interval": 5
    }
}
